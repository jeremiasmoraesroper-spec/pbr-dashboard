# ==========================================================================
#  Variáveis de ambiente — PBR Instagram Dashboard
#  Copie este arquivo para ".env.local" e preencha. NUNCA comite o .env.local.
#  Enquanto estiver vazio, o dashboard roda com DADOS DE EXEMPLO (seed).
# ==========================================================================

# --- Supabase (banco que guarda o histórico diário) ---
# Pegue em: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
# A chave "anon" pode ficar no frontend (só leitura via RLS). Opcional.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# A chave "service_role" é SECRETA — só no servidor (GitHub Actions / Vercel).
SUPABASE_SERVICE_ROLE_KEY=

# --- Supermetrics API (fonte oficial do Instagram) ---
# Pegue/gerencie em: https://hub.supermetrics.com/token-management
SUPERMETRICS_API_KEY=
# Conta do Instagram da PBR Brazil (data source IGI = Instagram Insights)
SUPERMETRICS_ACCOUNT_ID=17841401478253574
SUPERMETRICS_DS_ID=IGI

# --- Configuração da meta ---
GOAL_TARGET=2000000
GOAL_DATE=2026-12-31
